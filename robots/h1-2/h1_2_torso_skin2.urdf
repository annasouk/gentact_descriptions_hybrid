      <origin rpy="0 0 0" xyz="0.027967 -0.000096 0.000739"/>
      <mass value="0.124"/>
      <inertia ixx="137.3e-6" ixy="0.171e-6" ixz="2.942e-6" iyy="169.998e-6" iyz="0.025e-6" izz="84.808e-6"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/wrist_yaw_link.STL"/>
      </geometry>
      <material>
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/wrist_yaw_link.STL"/>
      </geometry>
    </collision> -->
  </link>
  <joint name="right_wrist_yaw_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.020 0 0"/>
    <parent link="right_wrist_pitch_link"/>
    <child link="right_wrist_yaw_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="19" lower="-1.27" upper="1.27" velocity="31.4"/>
  </joint>
  <!-- LOGO -->
  <link name="logo_link">
